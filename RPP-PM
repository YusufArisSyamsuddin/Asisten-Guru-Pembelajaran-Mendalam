                              <strong className="block text-blue-800 mb-2">Kesiapan Siswa</strong>
                              <p className="whitespace-pre-wrap">{rppData.kesiapanSiswa || "-"}</p>
                            </div>
                            <div className="bg-slate-50 p-4 rounded-lg border border-slate-200">
                              <strong className="block text-blue-800 mb-2">Materi Pelajaran</strong>
                              <p className="whitespace-pre-wrap">{rppData.karakteristikMateri || "-"}</p>
                            </div>
                            
                            <div className="grid lg:grid-cols-2 gap-4">
                              <div className="bg-slate-50 p-4 rounded-lg border border-slate-200">
                                <strong className="block text-blue-800 mb-3">Dimensi Profil Lulusan</strong>
                                <div className="grid grid-cols-1 sm:grid-cols-2 gap-3 text-sm">
                                  {Object.keys(profilLabels).map((key) => rppData.profilLulusan[key] && (
                                    <div key={key} className="flex items-center text-blue-900 font-medium bg-white p-2 rounded border border-blue-100 shadow-sm">
                                      <i className="fas fa-check-square text-blue-600 mr-2 text-lg"></i> {profilLabels[key]}
                                    </div>
                                  ))}
                                </div>
                              </div>
                              <div className="bg-blue-50 p-4 rounded-lg border border-blue-200">
