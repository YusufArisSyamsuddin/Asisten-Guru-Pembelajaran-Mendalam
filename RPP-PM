<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asisten Guru SMPN 2 Secang - Pembelajaran Mendalam</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- React & ReactDOM -->
    <script src="https://unpkg.com/react@18/umd/react.production.min.js" crossorigin></script>
    <script src="https://unpkg.com/react-dom@18/umd/react-dom.production.min.js" crossorigin></script>
    
    <!-- Babel -->
    <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

    <style>
        .scrollbar-hide::-webkit-scrollbar { display: none; }
        .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }
        
        @keyframes pulse-blue {
            0% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(37, 99, 235, 0); }
            100% { box-shadow: 0 0 0 0 rgba(37, 99, 235, 0); }
        }
        .btn-word {
            animation: pulse-blue 2s infinite;
        }
        .btn-word:hover {
            animation: none;
        }

        .table-input {
            width: 100%;
            background: transparent;
            border: 1px solid transparent;
            padding: 4px;
            outline: none;
            resize: vertical;
        }
        .table-input:focus {
            border: 1px solid #3b82f6;
            border-radius: 4px;
            background: #fff;
        }
        
        /* Animasi untuk dropdown */
        @keyframes slideDown {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .dropdown-animate {
            animation: slideDown 0.2s ease-out forwards;
        }
    </style>
</head>
<body class="bg-slate-50 font-sans text-slate-800">
    <div id="root"></div>

    <script type="text/babel">
        const { useState, useEffect, useRef } = React;

        const Card = ({ children, className = "" }) => (
          <div className={`bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden ${className}`}>
            {children}
          </div>
        );

        const Accordion = ({ title, icon, subtitle, children, defaultOpen = false, isCompleted, onToggleComplete, headerColorClass = "bg-blue-100 text-blue-700" }) => {
          const [isOpen, setIsOpen] = useState(defaultOpen);
          
          return (
            <Card className={`mb-5 transition-all duration-300 ${isCompleted ? 'border-l-4 border-l-green-500 opacity-80 bg-slate-50' : 'border-l-4 border-l-blue-600'}`}>
              <div className="flex items-center justify-between p-4 hover:bg-slate-50 cursor-pointer" onClick={() => setIsOpen(!isOpen)}>
                <div className="flex-1 flex items-center space-x-4 text-left">
                  <div className={`w-12 h-12 rounded-xl flex items-center justify-center shadow-sm ${isCompleted ? 'bg-green-100 text-green-700' : headerColorClass}`}>
                    <i className={`${icon} text-xl`}></i>
                  </div>
                  <div>
                    <h3 className={`font-bold text-lg ${isCompleted ? 'text-green-800 line-through decoration-green-400' : 'text-slate-800'}`}>
                      {title}
                    </h3>
                    {subtitle && <p className="text-sm font-medium text-slate-500 mt-0.5">{subtitle}</p>}
                  </div>
                </div>
                <div className="flex items-center space-x-3" onClick={(e) => e.stopPropagation()}>
                  <button 
                    onClick={onToggleComplete}
                    className={`w-8 h-8 rounded-full flex items-center justify-center border-2 transition-colors shadow-sm ${
                      isCompleted ? 'bg-green-500 border-green-500 text-white' : 'border-slate-300 bg-white text-transparent hover:border-green-400'
                    }`}
                    title="Tandai Selesai"
                  >
                    ✓
                  </button>
                  <button onClick={() => setIsOpen(!isOpen)} className="p-2">
                    {isOpen ? <i className="fas fa-chevron-up text-slate-500"></i> : <i className="fas fa-chevron-down text-slate-500"></i>}
                  </button>
                </div>
              </div>
              {isOpen && (
                <div className="p-5 border-t border-slate-200 bg-white overflow-x-auto">
                  {children}
                </div>
              )}
            </Card>
          );
        };

        const LabelWithHint = ({ children, hint, className="block text-slate-700 font-semibold mb-1" }) => {
            const [showHint, setShowHint] = useState(false);
            return (
                <div className="mb-1 w-full">
                    <div className="flex items-center justify-between">
                        <label className={className}>{children}</label>
                        {hint && (
                            <button
                                type="button"
                                onClick={() => setShowHint(!showHint)}
                                className={`ml-2 shrink-0 text-[10px] font-bold uppercase tracking-wider px-2 py-1 rounded transition-colors flex items-center shadow-sm ${showHint ? 'bg-blue-600 text-white hover:bg-blue-700' : 'bg-white border border-slate-300 text-slate-500 hover:bg-slate-100 hover:text-slate-800'}`}
                                title="Klik untuk bantuan pengisian"
                            >
                                <i className={`fas ${showHint ? 'fa-times' : 'fa-info-circle'} mr-1`}></i> {showHint ? 'Tutup' : 'Petunjuk'}
                            </button>
                        )}
                    </div>
                    {showHint && (
                        <div className="mt-2 mb-3 p-3 bg-blue-50/80 border border-blue-200 text-blue-800 text-xs rounded-lg shadow-inner leading-relaxed">
                            <i className="fas fa-lightbulb text-yellow-500 mr-2 text-sm"></i>
                            {hint}
                        </div>
                    )}
                </div>
            );
        };

        // KOMPONEN BARU: MULTI-SELECT DROPDOWN KUSTOM
        const MultiSelectDropdown = ({ options, selectedOptions, toggleOption }) => {
            const [isOpen, setIsOpen] = useState(false);
            const dropdownRef = useRef(null);

            useEffect(() => {
                function handleClickOutside(event) {
                    if (dropdownRef.current && !dropdownRef.current.contains(event.target)) {
                        setIsOpen(false);
                    }
                }
                document.addEventListener("mousedown", handleClickOutside);
                return () => document.removeEventListener("mousedown", handleClickOutside);
            }, [dropdownRef]);

            return (
                <div className="relative" ref={dropdownRef}>
                    <button
                        type="button"
                        onClick={() => setIsOpen(!isOpen)}
                        className="w-full p-3 border border-slate-300 rounded focus:ring-2 focus:ring-indigo-500 bg-white text-left flex justify-between items-center shadow-sm transition-colors hover:bg-slate-50"
                    >
                        <span className="truncate pr-4 text-slate-700 font-medium">
                            {selectedOptions.length > 0 
                                ? selectedOptions.join(', ') 
                                : '-- Klik untuk memilih Praktik Pedagogis (Bisa lebih dari 1) --'}
                        </span>
                        <div className="flex items-center">
                            {selectedOptions.length > 0 && (
                                <span className="bg-indigo-100 text-indigo-800 text-[10px] font-bold px-2 py-1 rounded-full mr-2">
                                    {selectedOptions.length} Dipilih
                                </span>
                            )}
                            <i className={`fas fa-chevron-${isOpen ? 'up' : 'down'} text-slate-500`}></i>
                        </div>
                    </button>

                    {isOpen && (
                        <div className="absolute z-50 mt-2 w-full bg-white border border-indigo-200 rounded-lg shadow-xl max-h-96 overflow-y-auto dropdown-animate">
                            <div className="p-2 bg-indigo-50 text-xs text-indigo-800 font-bold border-b border-indigo-100 sticky top-0 z-10">
                                <i className="fas fa-check-square mr-1"></i> Centang model/strategi yang digunakan:
                            </div>
                            {options.map((opt) => (
                                <div 
                                    key={opt.id} 
                                    className={`p-3 border-b border-slate-100 cursor-pointer flex items-start space-x-3 transition-colors ${selectedOptions.includes(opt.title) ? 'bg-indigo-50/50' : 'hover:bg-slate-50'}`}
                                    onClick={() => toggleOption(opt.title)}
                                >
                                    <input 
                                        type="checkbox" 
                                        className="mt-1 w-4 h-4 text-indigo-600 rounded cursor-pointer border-slate-300"
                                        checked={selectedOptions.includes(opt.title)}
                                        readOnly
                                    />
                                    <div className="flex-1">
                                        <div className={`text-sm font-bold ${selectedOptions.includes(opt.title) ? 'text-indigo-800' : 'text-slate-800'}`}>
                                            {opt.title}
                                        </div>
                                        <div className="text-xs text-slate-500 mt-1 leading-snug">
                                            {opt.desc}
                                        </div>
                                    </div>
                                </div>
                            ))}
                        </div>
                    )}
                </div>
            );
        };

        function App() {
          const [completedSteps, setCompletedSteps] = useState({});
          const [isEditing, setIsEditing] = useState(false);
          
          const profilLabels = {
            keimanan: "Keimanan dan Ketakwaan",
            penalaran: "Penalaran Kritis",
            kolaborasi: "Kolaborasi",
            kesehatan: "Kesehatan",
            kewargaan: "Kewargaan",
            kreativitas: "Kreativitas",
            kemandirian: "Kemandirian",
            komunikasi: "Komunikasi"
          };

          const kseLabels = {
            kesadaranDiri: "Kesadaran Diri",
            manajemenDiri: "Manajemen Diri",
            kesadaranSosial: "Kesadaran Sosial",
            keterampilanBerelasi: "Keterampilan Berelasi",
            keputusanBertanggungJawab: "Keputusan Bertanggung Jawab"
          };

          // DAFTAR PRAKTIK PEDAGOGIS LENGKAP (Sesuai Kurikulum Merdeka)
          const praktikOptions = [
            { id: 'ubd', title: "Understanding by Design (UbD)", desc: "Desain Mundur: Menentukan hasil akhir dan merancang asesmen terlebih dahulu sebelum menyusun aktivitas belajar." },
            { id: 'tarl', title: "Teaching at the Right Level (TaRL) / Diferensiasi", desc: "Instruksi yang disesuaikan dengan tingkat capaian atau kemampuan awal peserta didik (bukan sekadar berdasarkan usia/kelas)." },
            { id: 'crt', title: "Culturally Responsive Teaching (CRT)", desc: "Mengaitkan materi pelajaran dengan latar belakang budaya, kearifan lokal, dan lingkungan keseharian siswa." },
            { id: 'pbl', title: "Problem Based Learning (PBL)", desc: "Siswa secara aktif memecahkan masalah kontekstual dunia nyata untuk membangun pengetahuan dan nalar kritis." },
            { id: 'pjbl', title: "Project Based Learning (PjBL)", desc: "Siswa melakukan investigasi mendalam dan kolaboratif untuk menghasilkan sebuah produk atau karya nyata." },
            { id: 'inquiry', title: "Inquiry Based Learning", desc: "Siswa didorong proaktif menyusun pertanyaan, meneliti, dan menemukan konsep/fakta secara mandiri dengan bimbingan guru." },
            { id: 'discovery', title: "Discovery Learning", desc: "Proses pembelajaran di mana siswa menemukan sendiri pengetahuan baru melalui percobaan, pengamatan, dan inferensi." },
            { id: 'experiential', title: "Experiential Learning", desc: "Belajar dari pengalaman: Siklus mengalami secara langsung, mengobservasi, membuat konsep, dan menguji coba." },
            { id: 'cooperative', title: "Cooperative Learning", desc: "Belajar kolaboratif dalam kelompok kecil terstruktur di mana siswa saling membantu (Contoh: Jigsaw, STAD, TGT)." },
            { id: 'flipped', title: "Flipped Classroom", desc: "Materi dasar dipelajari mandiri di rumah, sementara waktu kelas difokuskan penuh untuk diskusi, tanya jawab, dan praktik." },
            { id: 'sel', title: "Pembelajaran Sosial Emosional (SEL)", desc: "Pengintegrasian keterampilan kesadaran diri, empati, relasi, dan regulasi emosi secara sengaja ke dalam mata pelajaran (CASEL)." },
            { id: 'montessori', title: "Pendekatan Montessori", desc: "Pembelajaran berpusat pada anak yang membebaskan siswa memilih aktivitas belajarnya secara mandiri dengan alat peraga khusus." },
            { id: 'lainnya', title: "Lainnya (Ketik Manual)", desc: "Pilih opsi ini jika Bapak/Ibu menggunakan model, metode, atau pendekatan spesifik lainnya." }
          ];
          
          const [rppData, setRppData] = useState(() => {
            const defaultData = {
              namaSekolah: "SMP Negeri 2 Secang",
              namaGuru: "YUSUF ARIS SYAMSUDDIN, S.Pd.",
              nipGuru: "-",
              namaKepsek: "NAMA KEPALA SEKOLAH, M.Pd.",
              nipKepsek: "-",
              tahunPelajaran: "2025/2026",
              mapel: "Ilmu Pengetahuan Alam (IPA)",
              kelas: "Fase D / Kelas VIII",
              topik: "Pengenalan Sel",
              waktu: "2 x 40 Menit",
              jumlahPertemuan: "1 Pertemuan",
              kompetensiAwal: "Peserta didik telah mempelajari Teori Sel secara dasar di kelas sebelumnya dan cukup familiar dalam menggunakan mikroskop.",
              kesiapanSiswa: "Mayoritas siswa terbiasa dengan lingkungan agraris. Sebagian butuh bimbingan intensif memahami konsep abstrak mikroskopis.",
              karakteristikMateri: "Materi bersifat abstrak. Memerlukan pendekatan kontekstual dan observasi langsung menggunakan mikroskop.",
              profilLulusan: { keimanan: true, penalaran: true, kolaborasi: true, kesehatan: false, kewargaan: false, kreativitas: false, kemandirian: false, komunikasi: false },
              kseLulusan: { kesadaranDiri: true, manajemenDiri: false, kesadaranSosial: true, keterampilanBerelasi: false, keputusanBertanggungJawab: false },
              cp: "Peserta didik dapat mengidentifikasi pewarisan sifat dan penerapan bioteknologi dalam kehidupan sehari-hari serta sel sebagai unit terkecil makhluk hidup.",
              lintasDisiplin: "Prakarya (merancang model sel tiga dimensi dari barang bekas).",
              tp: "Melalui kegiatan eksperimen pengamatan mikroskop, peserta didik dapat membedakan minimal 3 struktur organel sel hewan dan tumbuhan beserta fungsinya secara tepat.",
              praktikPedagogis: ["Understanding by Design (UbD)", "Teaching at the Right Level (TaRL) / Diferensiasi"],
              praktikLainnya: "",
              kemitraanPembelajaran: "Diskusi kolaboratif kelompok sebaya.",
              lingkunganPembelajaran: "Laboratorium IPA dan area taman sekolah.",
              pemanfaatanDigital: "Penggunaan LCD Proyektor untuk menampilkan video sel interaktif.",
              kegiatanAwal: "1. Guru menyapa dan melakukan Check-in kesiapan emosional siswa (Teknik STOP).\n2. Apersepsi (CRT): Mengaitkan perbedaan struktur tanaman dengan hewan ternak yang ada di lingkungan desa setempat.",
              kegiatanInti: "1. Stimulus: Siswa secara mandiri mengamati preparat sel daun dan epitel pipi di bawah mikroskop.\n2. Pembagian Kelompok (TaRL): Kelompok Bimbingan menggambar dan menjodohkan fungsi organel. Kelompok Mahir membuat analogi sistem sel menjadi sebuah 'pabrik/kota'.",
              kegiatanPenutup: "1. Masing-masing perwakilan kelompok melakukan presentasi singkat hasil temuan mereka.\n2. Guru memuliakan proses belajar dengan memberikan pujian spesifik (Prinsip Menggembirakan).",
              pengalamanMemahami: "Mengobservasi preparat sel menggunakan mikroskop secara langsung untuk menemukan pemahaman esensial bahwa sel hidup memiliki struktur khusus.",
              pengalamanMengaplikasi: "Merancang ide analogi sel secara berkelompok (misal: Nukleus = Kepala Desa, Mitokondria = Pembangkit Listrik) dan mempresentasikan gagasan tersebut.",
              pengalamanMerefleksi: "Menuliskan jurnal refleksi individu (Exit Ticket) terkait pemahaman materi apa yang sudah dikuasai dan bagian mana yang masih membingungkan.",
              asesmenAwal: "Kuis Lisan Cepat: 'Sebutkan bagian terkecil penyusun tubuh yang kalian ketahui!'",
              asesmenProses: "Observasi formatif selama diskusi kelompok berlangsung (Fokus Karakter Penilaian: Sikap Gotong Royong / Kolaborasi dan Keaktifan).",
              asesmenAkhir: "Tes Tertulis (Uraian Singkat) terkait kemampuan menjelaskan 3 fungsi organel spesifik.",
              kisiKisi: [ { id: 1, materi: "Pengenalan Sel", indikator: "Membedakan organel sel hewan dan tumbuhan", level: "C4", bentuk: "Uraian", nomor: "1" } ],
              bankSoal: [ { id: 1, soal: "Sebutkan 3 perbedaan utama antara anatomi sel hewan dan sel tumbuhan beserta dampaknya pada struktur fisiknya!" } ],
              rubrikPenilaian: [ { id: 1, skor: "Skor 4", kriteria: "Menyebutkan tepat 3 perbedaan struktural (seperti Dinding Sel, Vakuola, Kloroplas) dengan penjelasan logis dan runtut." } ],
              catatanRefleksi: ""
            };

            const savedData = localStorage.getItem('asistenGuruData_v21');
            if (savedData) {
              try { 
                let parsed = JSON.parse(savedData);
                // Konversi format lama (string) ke array jika terdeteksi
                if (typeof parsed.praktikPedagogis === 'string') {
                    parsed.praktikPedagogis = [parsed.praktikPedagogis];
                }
                return { ...defaultData, ...parsed, kseLulusan: parsed.kseLulusan || defaultData.kseLulusan }; 
              } catch (e) { console.error("Gagal memuat data", e); }
            }
            return defaultData;
          });

          useEffect(() => {
            localStorage.setItem('asistenGuruData_v21', JSON.stringify(rppData));
          }, [rppData]);

          const toggleStep = (stepId) => setCompletedSteps(prev => ({ ...prev, [stepId]: !prev[stepId] }));

          const handleInputChange = (e) => {
            const { name, value } = e.target;
            setRppData(prev => ({ ...prev, [name]: value }));
          };

          const handleProfilChange = (key) => {
            setRppData(prev => ({ ...prev, profilLulusan: { ...prev.profilLulusan, [key]: !prev.profilLulusan[key] } }));
          };

          const handleKseChange = (key) => {
            setRppData(prev => ({ ...prev, kseLulusan: { ...prev.kseLulusan, [key]: !prev.kseLulusan[key] } }));
          };

          const togglePraktikPedagogis = (model) => {
            setRppData(prev => {
                let current = Array.isArray(prev.praktikPedagogis) ? [...prev.praktikPedagogis] : [];
                if (current.includes(model)) {
                    current = current.filter(item => item !== model);
                } else {
                    current.push(model);
                }
                return { ...prev, praktikPedagogis: current };
            });
          };

          const handleTableChange = (arrayName, index, field, value) => {
            setRppData(prev => {
              const newArray = [...prev[arrayName]];
              newArray[index] = { ...newArray[index], [field]: value };
              return { ...prev, [arrayName]: newArray };
            });
          };

          const addTableRow = (arrayName, defaultObj) => {
            setRppData(prev => ({ ...prev, [arrayName]: [...prev[arrayName], { id: Date.now(), ...defaultObj }] }));
          };

          const removeTableRow = (arrayName, id) => {
            if(window.confirm("Hapus baris ini?")) {
              setRppData(prev => ({ ...prev, [arrayName]: prev[arrayName].filter(item => item.id !== id) }));
            }
          };

          const resetRppData = () => {
            if(window.confirm("Kosongkan semua form dan mulai dari nol?")) {
              const emptyData = {
                namaSekolah: rppData.namaSekolah, namaGuru: rppData.namaGuru, nipGuru: rppData.nipGuru, namaKepsek: rppData.namaKepsek, nipKepsek: rppData.nipKepsek,
                tahunPelajaran: "", mapel: "", kelas: "", topik: "", waktu: "", jumlahPertemuan: "", kompetensiAwal: "",
                kesiapanSiswa: "", karakteristikMateri: "", 
                profilLulusan: { keimanan: false, penalaran: false, kolaborasi: false, kesehatan: false, kewargaan: false, kreativitas: false, kemandirian: false, komunikasi: false },
                kseLulusan: { kesadaranDiri: false, manajemenDiri: false, kesadaranSosial: false, keterampilanBerelasi: false, keputusanBertanggungJawab: false },
                cp: "", lintasDisiplin: "", tp: "", 
                praktikPedagogis: [], praktikLainnya: "", kemitraanPembelajaran: "", lingkunganPembelajaran: "", pemanfaatanDigital: "",
                kegiatanAwal: "", kegiatanInti: "", kegiatanPenutup: "", pengalamanMemahami: "", pengalamanMengaplikasi: "", pengalamanMerefleksi: "",
                asesmenAwal: "", asesmenProses: "", asesmenAkhir: "", catatanRefleksi: "",
                kisiKisi: [], bankSoal: [], rubrikPenilaian: []
              };
              setRppData(emptyData);
              setCompletedSteps({});
              setIsEditing(true);
            }
          };

          // Helper format enter \n ke <br/> untuk Word
          const formatText = (txt) => txt ? txt.replace(/\n/g, '<br/>') : '';

          // Ekstraksi string final praktik pedagogis untuk Word & View Mode
          const getFinalPraktikString = () => {
              let finalArr = Array.isArray(rppData.praktikPedagogis) ? [...rppData.praktikPedagogis] : [];
              
              // Hapus label "Lainnya (Ketik Manual)" dari array final jika ada
              finalArr = finalArr.filter(item => item !== "Lainnya (Ketik Manual)");

              if (rppData.praktikPedagogis.includes("Lainnya (Ketik Manual)") && rppData.praktikLainnya && rppData.praktikLainnya.trim() !== "") {
                  finalArr.push(rppData.praktikLainnya);
              }
              return finalArr.length > 0 ? finalArr.join(', ') : '-';
          };

          const generateWordContent = () => {
            const kisiKisiRows = rppData.kisiKisi.length > 0 ? rppData.kisiKisi.map((k, i) => `<tr><td style="text-align:center; border: 1px solid black; padding: 4px;">${i+1}</td><td style="border: 1px solid black; padding: 4px;">${formatText(k.materi)}</td><td style="border: 1px solid black; padding: 4px;">${formatText(k.indikator)}</td><td style="text-align:center; border: 1px solid black; padding: 4px;">${k.level}</td><td style="text-align:center; border: 1px solid black; padding: 4px;">${k.bentuk}</td><td style="text-align:center; border: 1px solid black; padding: 4px;">${k.nomor}</td></tr>`).join('') : `<tr><td colspan="6" style="text-align:center; border: 1px solid black; padding: 4px;">Tidak ada data</td></tr>`;
            const bankSoalRows = rppData.bankSoal.length > 0 ? rppData.bankSoal.map((b, i) => `<tr><td style="text-align:center; border: 1px solid black; padding: 4px;">${i+1}</td><td style="border: 1px solid black; padding: 4px;">${formatText(b.soal)}</td></tr>`).join('') : `<tr><td colspan="2" style="text-align:center; border: 1px solid black; padding: 4px;">Tidak ada data</td></tr>`;
            const rubrikRows = rppData.rubrikPenilaian.length > 0 ? rppData.rubrikPenilaian.map((r) => `<tr><td style="border: 1px solid black; padding: 4px; font-weight: bold; vertical-align: top;">${formatText(r.skor)}</td><td style="border: 1px solid black; padding: 4px;">${formatText(r.kriteria)}</td></tr>`).join('') : `<tr><td colspan="2" style="text-align:center; border: 1px solid black; padding: 4px;">Tidak ada data</td></tr>`;

            const profilKeys = Object.keys(profilLabels);
            let profilHtml = '<table style="width:100%; border:none; margin:0; padding:0;">';
            for (let i = 0; i < profilKeys.length; i += 2) {
                const key1 = profilKeys[i];
                const key2 = profilKeys[i+1];
                const check1 = rppData.profilLulusan[key1] ? '☑' : '☐';
                const check2 = key2 ? (rppData.profilLulusan[key2] ? '☑' : '☐') : '';
                const label2 = key2 ? profilLabels[key2] : '';
                profilHtml += `<tr>
