                            </div>
                          </div>
                        </Card>

                        <Accordion title="TAHAP 1: Identifikasi" icon="fas fa-search" defaultOpen={true} isCompleted={completedSteps['t1']} onToggleComplete={() => toggleStep('t1')} headerColorClass="bg-blue-100 text-blue-700">
