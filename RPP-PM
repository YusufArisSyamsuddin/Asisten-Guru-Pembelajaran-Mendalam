                                <span className="bg-fuchsia-600 text-white w-8 h-8 rounded-lg flex items-center justify-center font-bold text-lg mr-3 shadow-sm">3</span>
                                <h4 className="font-black text-fuchsia-900 text-lg">FASE AKHIR <span className="font-normal text-fuchsia-700 ml-2">| Penutup & Evaluasi</span></h4>
                              </div>
                              <div className="flex flex-col">
                                 <div className="p-5 border-b border-slate-200 hover:bg-slate-50 transition-colors bg-slate-50/50">
                                    <span className="inline-flex items-center px-2.5 py-1 rounded bg-slate-100 text-slate-700 text-xs font-bold uppercase tracking-wider border border-slate-200 mb-3">
                                       <i className="fas fa-running mr-1.5 text-slate-500"></i> Aktivitas Kelas
                                    </span>
                                    <p className="text-slate-800 whitespace-pre-wrap leading-relaxed">{rppData.kegiatanPenutup}</p>
                                 </div>
                                 <div className="flex flex-col md:flex-row divide-y md:divide-y-0 md:divide-x divide-slate-200">
                                     <div className="flex-1 p-5 hover:bg-fuchsia-50 transition-colors">
