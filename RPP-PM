                                        </span>
                                        <p className="text-fuchsia-900 whitespace-pre-wrap leading-relaxed">{rppData.pengalamanMerefleksi}</p>
                                     </div>
                                     <div className="flex-1 p-5 hover:bg-red-50 transition-colors bg-red-50/30">
                                        <span className="inline-flex items-center px-2.5 py-1 rounded bg-red-100 text-red-800 text-xs font-bold uppercase tracking-wider border border-red-200 mb-3">
                                           <i className="fas fa-flag-checkered mr-1.5 text-red-500"></i> Asesmen Akhir
                                        </span>
                                        <p className="text-red-900 whitespace-pre-wrap leading-relaxed font-medium">{rppData.asesmenAkhir}</p>
                                     </div>
                                 </div>
                              </div>
                            </div>

                          </div>
                        </Accordion>
                        
                        {rppData.catatanRefleksi && (
                          <Card className="mb-6 border-t-4 border-t-red-500">
                            <div className="p-5 bg-white">
                              <h3 className="font-bold text-red-800 text-lg mb-2"><i className="fas fa-pen-nib mr-2"></i>Catatan Refleksi Guru</h3>
                              <p className="text-slate-700 whitespace-pre-wrap leading-relaxed p-4 bg-red-50 rounded-lg border border-red-100">{rppData.catatanRefleksi}</p>
                            </div>
                          </Card>
                        )}

                      </div>
                    )}
                  </div>
                </div>

                <div className="w-full md:w-72 shrink-0 order-1 md:order-2 relative md:sticky top-6 z-50">
                  <div className="bg-white p-4 rounded-2xl shadow-lg border-2 border-blue-100 flex flex-col space-y-3">
                    <div className="pb-3 mb-1 border-b border-slate-100">
                      <h4 className="font-bold text-slate-800 flex items-center"><i className="fas fa-cog text-blue-500 mr-2"></i> Panel Kontrol</h4>
                      <p className="text-xs text-slate-500 mt-1">Status: {isEditing ? <span className="text-orange-500 font-bold">Sedang Mengedit</span> : <span className="text-green-500 font-bold">Tersimpan</span>}</p>
                    </div>

                    {isEditing ? (
                      <button onClick={() => setIsEditing(false)} className="px-5 py-3.5 bg-green-600 text-white rounded-xl text-sm font-bold hover:bg-green-700 transition shadow-md w-full flex justify-center items-center">
                        <i className="fas fa-save mr-2 text-lg"></i> Simpan Modul
                      </button>
                    ) : (
                      <>
                        <div className="flex space-x-2 w-full">
                          <button onClick={() => setIsEditing(true)} className="flex-1 px-4 py-3 bg-slate-100 text-slate-700 rounded-xl text-sm font-bold hover:bg-slate-200 transition border border-slate-300 shadow-sm flex justify-center items-center">
                            <i className="fas fa-edit mr-2"></i> Edit
                          </button>
                          <button onClick={resetRppData} title="Hapus Semua Data" className="flex-1 px-4 py-3 bg-red-50 text-red-600 rounded-xl text-sm font-bold hover:bg-red-100 transition border border-red-200 shadow-sm flex justify-center items-center">
                            <i className="fas fa-trash-alt mr-2"></i> Hapus
                          </button>
                        </div>
                        <button onClick={handleDownloadWord} className="btn-word w-full px-5 py-3.5 bg-blue-600 text-white rounded-xl text-sm font-bold shadow-md hover:bg-blue-700 transition-all flex justify-center items-center">
                          <i className="fas fa-file-word mr-2 text-xl"></i> Unduh Format Word
                        </button>
                      </>
                    )}
                  </div>
                </div>

              </main>
            </div>
          );
        }

        const root = ReactDOM.createRoot(document.getElementById('root'));
        root.render(<App />);
    </script>
</body>
</html>
