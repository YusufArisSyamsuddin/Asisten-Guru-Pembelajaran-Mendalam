                            <div className="grid grid-cols-2 gap-6 text-base text-slate-700">
                              <div className="col-span-2 md:col-span-1 border-l-4 border-blue-500 bg-blue-50 p-3 rounded-r-lg">
                                 <strong className="block text-slate-500 text-sm uppercase tracking-wider mb-1">Mata Pelajaran</strong>
                                 <span className="font-bold text-blue-900 text-lg">{rppData.mapel} <span className="text-sm font-medium text-blue-600">({rppData.kelas})</span></span>
                              </div>
                              <div className="col-span-2 md:col-span-1 border-l-4 border-indigo-500 bg-indigo-50 p-3 rounded-r-lg">
                                 <strong className="block text-slate-500 text-sm uppercase tracking-wider mb-1">Topik Pembelajaran</strong>
                                 <span className="font-bold text-indigo-900 text-lg">{rppData.topik}</span>
                              </div>
                              <div><strong className="block text-slate-500 text-sm uppercase tracking-wider mb-1">Penyusun</strong>{rppData.namaGuru}</div>
                              <div><strong className="block text-slate-500 text-sm uppercase tracking-wider mb-1">Sekolah</strong>{rppData.namaSekolah}</div>
